// Prisma Schema
// 数据库模型定义

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  schemas  = ["i18n_project_schema"]
}

// ============================================
// 枚举定义
// ============================================

// 团队成员角色
enum TeamRole {
  ADMIN // 管理员：可管理成员、生成邀请链接
  EDITOR // 编辑者：可编辑内容
  READER // 只读

  @@schema("i18n_project_schema")
}

// 邀请链接状态
enum InviteStatus {
  ACTIVE // 有效
  USED // 已使用
  EXPIRED // 已过期
  REVOKED // 已撤销

  @@schema("i18n_project_schema")
}

// 操作类型
enum OperationType {
  CREATE_PROJECT // 创建项目
  UPDATE_PROJECT // 更新项目
  CREATE_KEY // 创建Key
  UPDATE_KEY // 更新Key
  DELETE_KEY // 删除Key
  CREATE_TRANSLATION // 创建翻译
  UPDATE_TRANSLATION // 更新翻译
  DELETE_TRANSLATION // 删除翻译

  @@schema("i18n_project_schema")
}

// ============================================
// 用户表
// ============================================
model User {
  id       String  @id @default(uuid())
  email    String? @unique
  name     String
  phone    String? @unique
  password String  @map("password")

  // 飞书
  feishuId String? @unique @map("feishu_id")

  // 个人资料
  avatar String?
  bio    String?

  // 账户状态
  isActive    Boolean   @default(true) @map("is_active")
  lastLoginAt DateTime? @map("last_login_at")

  // 关联
  refreshTokens   RefreshToken[]
  teamMembers     TeamMember[]
  ownedTeams      Team[]         @relation("TeamOwner")
  invitesSent     InviteLink[]   @relation("InviterRelation")
  invitesAccepted InviteLink[]   @relation("AccepterRelation")

  // 时间戳
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  operationLogs OperationLog[]

  @@map("users")
  @@schema("i18n_project_schema")
}

// ============================================
// 团队表
// ============================================
model Team {
  id   String @id @default(uuid())
  name String
  slug String @unique // URL 友好的团队标识

  // 团队所有者（创建者）
  ownerId String @map("owner_id")
  owner   User   @relation("TeamOwner", fields: [ownerId], references: [id])

  // 团队设置（预留）
  logo        String?
  description String?

  // 关联
  members     TeamMember[]
  projects    Project[]
  inviteLinks InviteLink[]

  // 时间戳
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([ownerId])
  @@map("teams")
  @@schema("i18n_project_schema")
}

// ============================================
// 团队成员表（用户-团队 多对多 + 角色）
// ============================================
model TeamMember {
  id String @id @default(uuid())

  // 关联
  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  teamId String @map("team_id")
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  // 角色
  role TeamRole @default(READER)

  // 加入时间
  joinedAt DateTime @default(now()) @map("joined_at")

  // 唯一约束：一个用户在一个团队只能有一个成员记录
  @@unique([userId, teamId])
  @@index([teamId])
  @@map("team_members")
  @@schema("i18n_project_schema")
}

// ============================================
// 项目表
// ============================================
model Project {
  id   String @id @default(uuid())
  name String
  slug String // URL 友好的项目标识

  // 所属团队
  teamId String @map("team_id")
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  // 项目设置
  description     String?
  sourceLocale    String   @default("zh-CN") @map("source_locale") // 源语言
  targetLanguages String[] @default(["en", "zh-CN"]) @map("target_languages") // 目标语言

  // 关联
  keys          I18nKey[]
  operationLogs OperationLog[]

  // 时间戳
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([teamId, slug])
  @@index([teamId])
  @@map("projects")
  @@schema("i18n_project_schema")
}

// ============================================
// I18n Key 表
// ============================================
model I18nKey {
  id          String  @id @default(uuid())
  projectId   String  @map("project_id")
  key         String
  description String?

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")
  i18Ntranslations I18nTranslation[]

  @@unique([projectId, key])
  @@index([projectId])
  @@map("i18n_keys")
  @@schema("i18n_project_schema")
}

// ============================================
// I18n Translation 表
// ============================================
model I18nTranslation {
  id    String @id @default(uuid())
  keyId String @map("key_id")
  text  String
  lang  String

  key I18nKey @relation(fields: [keyId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([keyId, lang])
  @@index([keyId])
  @@map("i18n_translations")
  @@schema("i18n_project_schema")
}

// ============================================
// 邀请链接表
// ============================================
model InviteLink {
  id String @id @default(uuid())

  // 邀请链接 token（用于 URL）
  token String @unique

  // 分配的角色
  role TeamRole @default(READER)

  // 状态与限制
  status    InviteStatus @default(ACTIVE)
  expiresAt DateTime     @map("expires_at")
  // 关联团队
  teamId    String       @map("team_id")
  team      Team         @relation(fields: [teamId], references: [id], onDelete: Cascade)

  // 邀请者
  inviteBy String @map("invite_by")
  inviter  User   @relation("InviterRelation", fields: [inviteBy], references: [id])

  //被邀请者
  acceptedBy String?
  accepter   User?   @relation("AccepterRelation", fields: [acceptedBy], references: [id])

  // 时间戳
  createdAt DateTime @default(now()) @map("created_at")

  @@index([token])
  @@index([teamId])
  @@index([inviteBy])
  @@map("invite_links")
  @@schema("i18n_project_schema")
}

// ============================================
// Refresh Token 表（JWT 双 token 管理）
// ============================================
model RefreshToken {
  id     String @id @default(uuid())
  token  String @unique
  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Token 信息
  expiresAt DateTime @map("expires_at")
  isRevoked Boolean  @default(false) @map("is_revoked") // 是否已撤销

  // 设备信息（多设备管理）
  userAgent String? @map("user_agent")
  ipAddress String? @map("ip_address")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([token])
  @@map("refresh_tokens")
  @@schema("i18n_project_schema")
}

// Operation log 表（操作记录表）
model OperationLog {
  id               String        @id @default(uuid())
  operationType    OperationType @map("operation_type")
  operatorId       String        @map("operator_id")
  operator         User          @relation(fields: [operatorId], references: [id], onDelete: Cascade)
  projectId        String?       @map("project_id")
  project          Project?      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  operationContent String        @map("operation_content")
  operationAt      DateTime      @map("operation_at")

  @@index([operatorId])
  @@index([projectId])
  @@map("operation_logs")
  @@schema("i18n_project_schema")
}
